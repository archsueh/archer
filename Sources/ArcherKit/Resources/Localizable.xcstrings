        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每个预设会在 + 菜单里成为一个终端入口，始终在配置的目录中打开，与当前工作区无关。"
          }
        }
      }
    },
    "Edit the raw JSON for any key not exposed above. Comments (`//`, `/* */`) are accepted.": {

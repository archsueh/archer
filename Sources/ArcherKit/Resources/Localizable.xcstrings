    "Each preset becomes a Terminal entry in the + menu that always spawns in the configured folder, regardless of the active workspace.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每个预设会在 + 菜单里成为一个终端入口，始终在配置的目录中打开，与当前工作区无关。"
